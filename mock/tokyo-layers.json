  "stories": {
    "nihonbashi": {
      "1900": {
        "title": "五街道の起点",
        "description": "江戸時代から続く日本の道路網の起点。魚河岸が賑わい、両替商が軒を連ねた。1911年に現在の石造アーチ橋が完成。",
        "peak": false,
        "features": ["魚河岸", "両替商", "石造アーチ橋"]
      },
      "1955": {
        "title": "首都高に覆われた橋",
        "description": "戦災を免れた橋の上空に首都高速道路が建設。日本橋の景観は失われたが、周辺は百貨店と問屋街として復興。",
        "peak": false,
        "features": ["首都高建設", "百貨店", "問屋街"]
      },
      "1985": {
        "title": "金融の中心地",
        "description": "証券会社・銀行が集中し、兜町と一体で日本の金融の心臓部に。バブル経済の熱狂の中心。",
        "peak": true,
        "features": ["証券取引所", "金融街", "バブル経済"]
      },
      "2025": {
        "title": "首都高地下化と再生",
        "description": "首都高の地下化工事が進行中。日本橋の空が半世紀ぶりに開放される。COREDO室町など再開発ビルが林立。",
        "peak": false,
        "features": ["首都高地下化", "COREDO室町", "再開発"]
      }
    },
    "ginza4": {
      "1900": {
        "title": "煉瓦街の銀座",
        "description": "1872年の大火後、政府主導で煉瓦造の街並みに。文明開化の象徴として「銀ブラ」文化が生まれた。",
        "peak": false,
        "features": ["煉瓦街", "文明開化", "銀ブラ"]
      },
      "1955": {
        "title": "焼け野原からの復活",
        "description": "空襲で壊滅するも、いち早く復興。三越・松屋などの百貨店が再建され、再び日本一の繁華街に。",
        "peak": false,
        "features": ["百貨店再建", "繁華街復興", "ネオンサイン"]
      },
      "1985": {
        "title": "世界のGINZA",
        "description": "海外高級ブランドが続々と進出。地価は世界最高を記録。「銀座で買い物」が豊かさの象徴だった時代。",
        "peak": true,
        "features": ["高級ブランド", "地価世界一", "バブル"]
      },
      "2025": {
        "title": "体験型の街へ",
        "description": "GINZA SIXを筆頭に、物販からアート・食・体験へ軸足を移す。歩行者天国は健在。",
        "peak": false,
        "features": ["GINZA SIX", "体験型商業", "歩行者天国"]
      }
    },
    "marunouchi": {
      "1900": {
        "title": "三菱ヶ原",
        "description": "陸軍練兵場跡地を三菱が買収。一面の原っぱに「一丁倫敦」計画で赤煉瓦オフィス街を建設開始。",
        "peak": false,
        "features": ["三菱買収", "一丁倫敦", "赤煉瓦"]
      },
      "1955": {
        "title": "ビジネス街の確立",
        "description": "戦前からのオフィス街が本格復興。丸ビルを中心にサラリーマンの街として定着。夜は無人の街だった。",
        "peak": false,
        "features": ["丸ビル", "サラリーマン", "昼の街"]
      },
      "1985": {
        "title": "日本経済の司令塔",
        "description": "大手町・丸の内に日本を代表する企業の本社が集中。日本経済の絶頂期を支えた。",
        "peak": true,
        "features": ["企業本社集中", "経済絶頂期", "ビジネス中心"]
      },
      "2025": {
        "title": "丸の内仲通りの変貌",
        "description": "オフィス一辺倒から脱却。仲通りはカフェやブランド店が並ぶ歩行者空間に。東京駅復元も完了。",
        "peak": false,
        "features": ["仲通り", "複合用途", "東京駅復元"]
      }
    },
    "tokyo-station": {
      "1900": {
        "title": "建設前夜",
        "description": "辰野金吾設計の中央停車場が着工。1914年に開業予定。まだ更地と仮駅の時代。",
        "peak": false,
        "features": ["辰野金吾", "中央停車場計画", "着工"]
      },
      "1955": {
        "title": "戦災復旧の2階建て駅舎",
        "description": "空襲で3階部分を焼失し、応急的に2階建てに改修。新幹線開業（1964年）を控え、拡張計画が進行。",
        "peak": false,
        "features": ["戦災復旧", "2階建て駅舎", "新幹線計画"]
      },
      "1985": {
        "title": "新幹線ハブ",
        "description": "東海道・東北新幹線の起点として日本の交通の要に。地下には総武線・京葉線が乗り入れ。",
        "peak": false,
        "features": ["新幹線起点", "地下路線拡張", "交通ハブ"]
      },
      "2025": {
        "title": "復元された赤煉瓦駅舎",
        "description": "2012年に辰野金吾オリジナルの3階建てドーム屋根を復元。東京ステーションホテルも再開業。",
        "peak": true,
        "features": ["駅舎復元", "ドーム屋根", "ステーションホテル"]
      }
    },
    "tsukiji": {
      "1900": {
        "title": "海軍用地と外国人居留地",
        "description": "築地本願寺の門前町であり、海軍の施設が広がる。外国人居留地の名残も。",
        "peak": false,
        "features": ["海軍施設", "本願寺門前", "外国人居留地"]
      },
      "1955": {
        "title": "東京の台所",
        "description": "1935年に日本橋から移転した中央卸売市場が戦後復興。「築地の目利き」が東京の食を支えた。",
        "peak": false,
        "features": ["中央卸売市場", "食文化", "目利き"]
      },
      "1985": {
        "title": "世界最大の魚市場",
        "description": "マグロの競りは世界的に有名に。場外市場も観光地として賑わう。老朽化問題も浮上。",
        "peak": true,
        "features": ["マグロ競り", "場外市場", "世界的知名度"]
      },
      "2025": {
        "title": "市場移転後の再開発",
        "description": "2018年に豊洲へ移転。跡地は大規模再開発が進行中。場外市場は存続し観光客で賑わう。",
        "peak": false,
        "features": ["豊洲移転", "跡地再開発", "場外市場存続"]
      }
    },
    "hibiya": {
      "1900": {
        "title": "陸軍練兵場から公園へ",
        "description": "1903年に日本初の洋風公園として開園。帝国ホテル（初代）も1890年に開業済み。",
        "peak": false,
        "features": ["日比谷公園", "帝国ホテル", "洋風公園"]
      },
      "1955": {
        "title": "映画の殿堂",
        "description": "日比谷映画街が全盛期。東宝・松竹の大劇場が並び、映画が大衆娯楽の王様だった。",
        "peak": true,
        "features": ["映画街", "大劇場", "大衆娯楽"]
      },
      "1985": {
        "title": "ビジネスと文化の境界",
        "description": "映画館は減少するも、日生劇場・帝国劇場がミュージカルの中心地に。公園は都会のオアシス。",
        "peak": false,
        "features": ["ミュージカル", "日生劇場", "都会のオアシス"]
      },
      "2025": {
        "title": "東京ミッドタウン日比谷",
        "description": "2018年に大型複合施設が開業。映画・劇場・商業が融合した新しい文化拠点に。",
        "peak": false,
        "features": ["ミッドタウン日比谷", "複合文化施設", "再開発"]
      }
    },
    "kayabacho": {
      "1900": {
        "title": "水運と商いの街",
        "description": "日本橋川と亀島川の合流点。舟運で栄え、米問屋や醤油問屋が集まった。",
        "peak": true,
        "features": ["水運", "問屋街", "川の合流点"]
      },
      "1955": {
        "title": "証券街の裏方",
        "description": "兜町の証券取引所を支える事務所街。中小の証券会社や印刷所が密集。",
        "peak": false,
        "features": ["証券関連", "事務所街", "印刷所"]
      },
      "1985": {
        "title": "金融補完エリア",
        "description": "大手金融機関のバックオフィスが集積。地味だが日本経済を裏で支えた。",
        "peak": false,
        "features": ["バックオフィス", "金融補完", "堅実"]
      },
      "2025": {
        "title": "リノベーションの街",
        "description": "古いビルをカフェやコワーキングに転用するリノベが進行。若い起業家が集まるエリアに変貌中。",
        "peak": false,
        "features": ["リノベーション", "カフェ", "スタートアップ"]
      }
    },
    "kanda": {
      "1900": {
        "title": "職人と書生の街",
        "description": "江戸時代からの職人町。明治になると大学が近く、書生や学生が多く住んだ。古書店街の原型。",
        "peak": false,
        "features": ["職人町", "書生", "古書店"]
      },
      "1955": {
        "title": "神田古書店街の黄金期",
        "description": "世界最大級の古書店街として確立。学生運動の拠点にもなった知の街。",
        "peak": true,
        "features": ["古書店街", "学生運動", "知の街"]
      },
      "1985": {
        "title": "電気街との共存",
        "description": "秋葉原の電気街が拡大し、神田との境界が曖昧に。古書と電子部品が隣り合う不思議な街。",
        "peak": false,
        "features": ["電気街隣接", "古書店健在", "混在文化"]
      },
      "2025": {
        "title": "カレーとカルチャーの街",
        "description": "神田カレーグランプリで「カレーの街」としてブランド化。古書店は減少するも個性派書店が健在。",
        "peak": false,
        "features": ["カレーの街", "個性派書店", "文化ブランド"]
      }
    }
  },

