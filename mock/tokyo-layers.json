    "edo-castle": {
      "1456": {
        "title": "太田道灌の築城",
        "description": "扇谷上杉家の家臣・太田道灌が武蔵野台地の東端に城を築く。眼下には日比谷入江が広がり、天然の要害だった。",
        "peak": false,
        "features": ["太田道灌", "武蔵野台地", "日比谷入江"]
      },
      "1603": {
        "title": "徳川家康の居城",
        "description": "家康が天下普請で大規模改築。日比谷入江を埋め立て、螺旋状の堀と城下町を一体整備。世界最大級の城郭に。",
        "peak": true,
        "features": ["天下普請", "螺旋状の堀", "城下町整備"]
      },
      "1900": {
        "title": "皇居",
        "description": "明治維新で天皇が京都から遷御。旧江戸城は皇居となり、西の丸に宮殿を建設。",
        "peak": false,
        "features": ["皇居", "明治宮殿", "遷都"]
      }
    },
